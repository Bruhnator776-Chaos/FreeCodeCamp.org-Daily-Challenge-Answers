"""
Given a string, return the letter from the string that appears last in the alphabet.

- If two or more letters tie for the last in the alphabet, return the first one.
- Ignore all non-letter characters.
"""

# CODE #

def get_last_letter(s):
    s = "".join(list(filter(lambda x:x.isalpha(), [c for c in s]))) # Re-write the string to only alphabetical characters
    last_letter = s[0] # Set the last_letter variable to the first letter in the string
    for character in s[1:]: last_letter = character if ord(last_letter[0].lower()) < ord(character.lower()) else last_letter # Set the last_letter variable to the first occurence of the last-most letter of the alphabet found in the string
    return last_letter # Return the last letter
