"""
Given an array of strings representing chess pieces you still have on the board, calculate the value of the pieces your opponent has captured.

In chess, you start with 16 pieces:
    Piece	Abbreviation	Quantity	Value
    Pawn	"P"	            8	        1
    Rook	"R"	            2	        5
    Knight	"N"	            2	        3
    Bishop	"B"	            2	        3
    Queen	"Q"	            1	        9
    King	"K"	            1	        0

- The given array will only contain the abbreviations above.
- Any of the 16 pieces not included in the given array have been captured.
- Return the total value of all captured pieces, unless...
- If the King has been captured, return "Checkmate".
"""

# CODE #

def get_captured_value(pieces):
    if "K" not in pieces: return "Checkmate" # If the King was captured, return Checkmate
    total_pieces, point_values = { "P":8,"R":2,"N":2,"B":2,"Q":1,"K":1 }, { "P":1,"R":5,"N":3,"B":3,"Q":9,"K":0 } # Create a list of the total pieces on the board of a color before captures and a dictionary representing the point values associated with each piece
    for piece in pieces: total_pieces[piece] -= 1 # For each piece in the pieces argument, remove one from the count of that piece
    return sum([count*point_values[piece] for piece, count in total_pieces.items()]) # Take each count of the remaining pieces, and per piece, multiply that number by its point value. Using those final numbers, sum them together and return that total.
