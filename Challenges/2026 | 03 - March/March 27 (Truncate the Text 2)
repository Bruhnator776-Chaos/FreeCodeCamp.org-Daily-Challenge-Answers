"""
Given a string, return a new string that is truncated so that the total width of the characters does not exceed 50 units.

Each character has a specific width:
    Letters	                    Width
    "ilI"	                    1
    "fjrt"	                    2
    "abcdeghkmnopqsuvwxyzJL"	3
    "ABCDEFGHKMNOPQRSTUVWXYZ"	4

The table above includes all upper and lower case letters.

Additionally:
- Spaces (" ") have a width of 2
- Periods (".") have a width of 1
- If the given string is 50 units or less, return the string as-is, otherwise
- Truncate the string and add three periods at the end ("...") so its total width, including the three periods, is as close as possible to 50 units without going over.
"""

# CODE #

def get_units(s):
    """ Given a string, return the width """
    units = 0
    for char in s:
        if char in "ilI.": units += 1
        if char in "fjrt ": units += 2
        if char in "abcdeghkmnopqsuvwxyzJL": units += 3
        if char in "ABCDEFGHKMNOPQRSTUVWXYZ": units += 4
    return units

def truncate_text(s):
    if get_units(s) <= 50: return s # If the width of the string is under 50 units, return the string
    while get_units(s) > 47: s = s[:-1] # While the width of the string is greater than 47, remove the final character from the string
    return s+"..." # Return the string with 3 periods at the end
