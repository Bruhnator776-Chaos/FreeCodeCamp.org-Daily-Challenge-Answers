"""
Given a string representing a Roman numeral, return its integer value.

Roman numerals consist of the following symbols and values:
    Symbol	Value
    I   	1
    V   	5
    X   	10
    L	    50
    C	    100
    D	    500
    M	    1000

- Numerals are read left to right. If a smaller numeral appears before a larger one, the value is subtracted. Otherwise, values are added.
"""

# CODE #

def parse_roman_numeral(numeral):
    numeral = [{"I":1,"V":5,"X":10,"L":50,"C":100,"D":500,"M":1000}[n] for n in numeral] # Restructure the numeral into integers
    add, subtract = [numeral[-1]], [] # Create lists to hold all of the values that add to the total, and all the values that subtract from the total
    for i in range(len(numeral)-1): subtract.append(numeral[i]) if numeral[i] < numeral[i+1] else add.append(numeral[i]) # Sort values into subtracted and added values
    return sum(add)-sum(subtract) # Subtract the sum of the _subtract_ values from the sum of the _add_ values, and return the value
